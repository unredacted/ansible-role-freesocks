{# templates/remnanode-caddyfile.j2
   Rendered to /etc/caddy/Caddyfile.

   Data-driven, path-routed multi-transport model: each enabled entry in
   remnawave_cdn_transports gets a Caddy route to its loopback Xray inbound,
   and every other path falls through to a decoy/camouflage site. Caddy
   auto-binds port 80 for ACME HTTP-01 + HTTPS redirects; the site block listens
   on remnawave_caddy_listen_port (default 443) and terminates TLS.

   - ws    -> exact path match, reverse_proxy to the inbound (the WebSocket
              upgrade passes through transparently).
#}
{
    email {{ remnawave_caddy_email }}
}

{{ dns_hostname }}:{{ remnawave_caddy_listen_port }} {
{% for t in remnawave_cdn_transports if (t.enabled | default(true)) %}
{% if t.network == 'ws' %}
    @{{ t.name }} path {{ t.path }}
    handle @{{ t.name }} {
        reverse_proxy 127.0.0.1:{{ t.internal_port }}
    }
{% endif %}
{% endfor %}
    handle {
        root * {{ remnawave_decoy_root }}
        file_server
    }
}
